{
  "name": "catalyst-viewer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sst dev",
    "build": "sst build",
    "deploy": "sst deploy",
    "remove": "sst remove",
    "console": "sst console",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:smoke": "node --env-file=.env.local node_modules/@playwright/test/cli.js test",
    "test:smoke:int": "STAGE=int node_modules/@playwright/test/cli.js test",
    "quote": "esrun packages/core/src/bonds/catalyst/catalyst.ts quote",
    "classify-issuer": "esrun packages/core/src/issuers/cli.ts",
    "email": "esrun packages/functions/src/emails/testEmail.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "sst": "4.9.0",
    "typescript": "5.8.3",
    "vitest": "^3.1.1"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "esrun": "3.2.30"
  },
  "overrides": {
    "react": "^19",
    "react-dom": "^19",
    "@types/react": "^19",
    "@types/react-dom": "^19"
  }
}
