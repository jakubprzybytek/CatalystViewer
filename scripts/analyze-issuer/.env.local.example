# Tavily API key — get from https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# DynamoDB table name for IssuerProfiles (single-table design)
# Find the actual name in the AWS console or from `sst dev` output
# If not set, the script runs in dry-run mode (no DynamoDB write)
ISSUER_PROFILES_TABLE_NAME=replace-with-actual-table-name
